# Build from repository root: docker build -f platform/docker/Dockerfile.api .
FROM ghcr.io/astral-sh/uv:python3.11-bookworm-slim

WORKDIR /app
COPY pyproject.toml README.md LICENSE /app/
COPY src /app/src
COPY platform/api /app/platform/api
WORKDIR /app/platform/api
RUN uv sync --no-dev

ENV PYTHONUNBUFFERED=1
EXPOSE 8000

CMD ["uv", "run", "uvicorn", "crawlee_platform.api_app:app", "--host", "0.0.0.0", "--port", "8000"]
